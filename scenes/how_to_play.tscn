[node name="ObjectiveText" type="Label" parent="Panel/VBoxContainer/ScrollContainer/ScrollVBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "Dive into the ocean for a 90-second. Clean up trash and rescue trapped marine creatures to restore ocean health. Avoid running out of oxygen!"
autowrap_mode = 2

[node name="GameplayHeader" type="Label" parent="Panel/VBoxContainer/ScrollContainer/ScrollVBox"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.784314, 0.156863, 1)
theme_override_font_sizes/font_size = 24
text = "Cleanup & Rescues"

[node name="GameplayText" type="Label" parent="Panel/VBoxContainer/ScrollContainer/ScrollVBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "• Clean Trash: Swim into plastic bottles or bags to collect them.
• Rescue Marine Life: Swim into nets trapping fish or turtles to free them. Trapped animals perish after 15 seconds if ignored, harming ocean ecosystem.
• Ghost Nets: If entangled, you will be slowed down and lose oxygen until you struggle free and collect them (takes 2 seconds)."
autowrap_mode = 2

[node name="DiveHeader" type="Label" parent="Panel/VBoxContainer/ScrollContainer/ScrollVBox"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.784314, 0.156863, 1)
theme_override_font_sizes/font_size = 24
text = "Oxygen & Ocean Health"

[node name="DiveText" type="Label" parent="Panel/VBoxContainer/ScrollContainer/ScrollVBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "• Oxygen Level: Consumed continuously. Swim up to the surface to quickly refill.
• Ocean Health: Leftover pollution and trapped fish/turtles slowly decay the ecosystem."
autowrap_mode = 2

[node name="ControlsHeader" type="Label" parent="Panel/VBoxContainer/ScrollContainer/ScrollVBox"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.784314, 0.156863, 1)
theme_override_font_sizes/font_size = 24
text = "Controls & UI Navigation"

[node name="ControlsText" type="Label" parent="Panel/VBoxContainer/ScrollContainer/ScrollVBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "• Movement: Drag the Virtual Joystick (mobile) or use WASD / Arrow Keys (PC).
• Pause Game: Press the Pause button (Pause) on the left side of the screen or press Escape on keyboard.
• Rescue Pointer: A glowing red arrow rotates around your character, pointing directly to the nearest trapped animal."
autowrap_mode = 2

[node name="AwarenessHeader" type="Label" parent="Panel/VBoxContainer/ScrollContainer/ScrollVBox"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.784314, 0.156863, 1)
theme_override_font_sizes/font_size = 24
text = "Awareness thought bubbles"

[node name="AwarenessText" type="Label" parent="Panel/VBoxContainer/ScrollContainer/ScrollVBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "• Fact Bubbles: Collecting trash or freeing animals releases thought bubbles. Read them to learn real environmental facts!
• Effort Evaluation: At the end of the dive, you will receive a scorecard rating your effort (Low, Moderate, High) and describing your contribution to the ocean habitat."
autowrap_mode = 2

